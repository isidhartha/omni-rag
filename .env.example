# =============================================================================
# OmniRAG — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# LLM API Keys
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Embedding configuration
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ChromaDB (vector store)
CHROMA_HOST=chromadb
CHROMA_PORT=8001
CHROMA_COLLECTION=omnirag_docs

# PostgreSQL (document metadata)
DATABASE_URL=postgresql://omnirag:password@postgres:5432/omnirag

# Redis (conversation memory & caching)
REDIS_URL=redis://redis:6379

# Chunking parameters
CHUNK_SIZE=512
CHUNK_OVERLAP=50
MAX_RESULTS=10

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# File upload
UPLOAD_DIR=/tmp/omnirag/uploads
INDEX_DIR=/tmp/omnirag/index
